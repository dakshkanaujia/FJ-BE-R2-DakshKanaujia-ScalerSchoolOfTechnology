# Copy to .env and fill in values.

SECRET_KEY=change-me-to-a-long-random-string
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Database — provide DATABASE_URL or the discrete DB_* vars.
# DATABASE_URL=postgres://user:password@host:5432/dbname
DB_NAME=finance_tracker
DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=localhost
DB_PORT=5432
# Set True to use SQLite locally.
USE_SQLITE=False

# Google OAuth — leave blank to disable the Google login button.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Email notifications — defaults to console backend when not set.
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.resend.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=resend
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=no-reply@yourdomain.com

# Anthropic Claude (LLM insights) — optional, falls back to rule-based text.
ANTHROPIC_API_KEY=
